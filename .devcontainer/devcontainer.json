{
  "name": "scanner",
  "dockerFile": "Dockerfile",
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "PYTHONUNBUFFERED": "1",
    "VERBOSE": "1",
    "WORKERS": "8",
    "IPATOOL_PAR": "2"
  },
  "postCreateCommand": "bash ./scripts/install_ipatool.sh || true",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/local/bin/python3"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}